{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Asia/Tokyo",
  "schedule": ["before 9am on saturday"],
  "labels": ["dependencies", "renovate"],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "separateMinorPatch": true,
  "cargo": {
    "enabled": true
  },
  "mise": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on saturday"]
  },
  "minimumReleaseAge": "7 days",
  "automerge": true,
  "major": {
    "minimumReleaseAge": "14 days",
    "automerge": false
  },
  "packageRules": [
    {
      "description": "Group all non-major Rust crate updates into a single PR",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "cargo dependencies"
    },
    {
      "description": "Group Rust toolchain updates managed by mise",
      "matchManagers": ["mise"],
      "matchPackageNames": ["rust"],
      "groupName": "rust toolchain"
    }
  ]
}
